{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Facet desktop",
	"version": "0.1.0",
	"identifier": "com.facet.desktop",
	"build": {
		"beforeDevCommand": "pnpm exec vite",
		"beforeBuildCommand": "pnpm exec vite build",
		"devUrl": "http://localhost:5180",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "Facet desktop",
				"width": 1200,
				"height": 800,
				"resizable": true
			}
		],
		"security": {
			"csp": null,
			"assetProtocol": {
				"enable": true,
				"scope": ["**"]
			}
		}
	},
	"bundle": {
		"active": true,
		"targets": ["nsis"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"createUpdaterArtifacts": true
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFCNEEyM0Q2MkE1QjREREYKUldUZlRWc3ExaU5LRzRpMTFyR0pCVjZuQlZhMDZ5cFRtaXFqRTAzL2o5Tk1jRVZlMGY0Y081NXcK",
			"endpoints": [
				"https://github.com/zinmacky/facet/releases/latest/download/latest.json"
			],
			"windows": {
				"installMode": "passive"
			}
		}
	}
}
