{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Facet desktop",
	"version": "0.0.0",
	"identifier": "com.facet.desktop",
	"build": {
		"beforeDevCommand": "pnpm exec vite",
		"beforeBuildCommand": "pnpm exec vite build",
		"devUrl": "http://localhost:5180",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "Facet desktop",
				"width": 1200,
				"height": 800,
				"resizable": true
			}
		],
		"security": {
			"csp": null,
			"assetProtocol": {
				"enable": true,
				"scope": ["**"]
			}
		}
	},
	"bundle": {
		"active": true,
		"targets": "all"
	}
}
