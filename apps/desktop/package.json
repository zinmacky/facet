{
	"name": "@facet/desktop",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "tauri dev",
		"dev:public": "tauri dev --config src-tauri/tauri.dev-public.conf.json",
		"dev:mock": "vite --mode mock --port 5190",
		"build": "vite build",
		"build:win-release": "tauri build --config src-tauri/tauri.win-release.conf.json",
		"build:mac-local": "tauri build --config src-tauri/tauri.mac-local.conf.json",
		"build:mac-private": "node scripts/build-private.mjs mac",
		"build:win-private": "node scripts/build-private.mjs win",
		"preview": "vite preview",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"dependencies": {
		"@facet/contract": "workspace:*",
		"@facet/core": "workspace:*",
		"@tanstack/react-query": "^5.56.2",
		"@tauri-apps/api": "^2.11.1",
		"@tauri-apps/plugin-dialog": "^2",
		"@tauri-apps/plugin-notification": "^2",
		"@tauri-apps/plugin-opener": "^2.5.4",
		"@tauri-apps/plugin-process": "^2.3.1",
		"@tauri-apps/plugin-updater": "^2.10.1",
		"react": "^18.3.1",
		"react-dom": "^18.3.1"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4",
		"@tauri-apps/cli": "^2.11.4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/react": "^18.3.9",
		"@types/react-dom": "^18.3.0",
		"@vitejs/plugin-react": "^5.2.0",
		"jsdom": "^29.1.1",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.3",
		"vite": "^7.3.6",
		"vitest": "^3.2.7"
	}
}
